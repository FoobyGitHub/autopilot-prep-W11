[Version]
Signature   = "$Windows NT$"
Class		= HIDClass
ClassGuid	= {745a17a0-74d3-11d0-b6fe-00a0c90f57da};HIDClassGuid
Provider    = %VenderName%
DriverVer = 11/26/2025,16.0.0.41
CatalogFile = AsusPTPFilter.cat
pnplockdown = 1

[DestinationDirs]
DefaultDestDir					= 12   ; DIRID_DRIVERS
AsusFilter_Inst.CopyFiles.NT	= 13    ; Driver directory

; ---------------------------------------------------------
; Source Media Section
; ---------------------------------------------------------
[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
AsusPTPFilter.sys = 1
AsusPTPService.exe = 1
LaunchApp.exe = 1
AsusBusinessIntelligenceCPPLib.dll = 1
;----------------------------------------------------------------------------
; Common File Copy and Registry Operations
;----------------------------------------------------------------------------
[AsusFilter_Inst.CopyFiles.NT]
AsusPTPFilter.sys
AsusPTPService.exe
LaunchApp.exe
AsusBusinessIntelligenceCPPLib.dll

;----------------------------------------------------------------------------
; Manufacturer Section
;----------------------------------------------------------------------------
[Manufacturer]
%VenderName%=ASUSMfg, NTamd64.10.0...16299


