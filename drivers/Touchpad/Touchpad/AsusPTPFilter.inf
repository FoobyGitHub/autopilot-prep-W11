[AsusFilterDrv_Service_Drv_AddReg]
HKR,Parameters\DriverParameters,"DRV_FLAG_1",0x00010001,3		; bit0: Use static parser, bit1: adjust button area; bit2: MS wakeup (0:btn,1:btn+touch)  
HKR,Parameters\DriverParameters,"DRV_FLAG_2",0x00010001,7		; bit0: Y98, bit1: Y84, bit2:Y77, others: Don't care
HKR,Parameters\DriverParameters,"DRV_FLAG_3",0x00010001,21		; Y77: The allocated height of the touchpad's button area
HKR,Parameters\DriverParameters,"DRV_FLAG_4",0x00010001,21		; Y84: The allocated height of the touchpad's button area
HKR,Parameters\DriverParameters,"DRV_FLAG_5",0x00010001,21		; Y98: The allocated height of the touchpad's button area
HKR,Parameters\DriverParameters,"DRV_FLAG_6",0x00010001,0		; Status: static buffer handler enable(1)/disable(0)


HKR,Parameters\DriverParameters,"STATUS_00",0x00010001,0		; Record status happend. [Read] bit0: retry, bit1: reinit, bit2: static buffer count, [SHM] bit3~5, bit6: static buffer enable
;readraw packet
HKR,Parameters\DriverParameters,"STATUS_01",0x00010001,0		; List retry mechanism: retry num 0~10
HKR,Parameters\DriverParameters,"STATUS_02",0x00010001,0		; List reinit: 0, 1
HKR,Parameters\DriverParameters,"STATUS_03",0x00010001,0		; List insert fail num. Record the static buffer count. 0~10
;SHMraw packet
HKR,Parameters\DriverParameters,"STATUS_04",0x00010001,0		; List retry mechanism: retry num 0~10
HKR,Parameters\DriverParameters,"STATUS_05",0x00010001,0		; List reinit: 0, 1
HKR,Parameters\DriverParameters,"STATUS_06",0x00010001,0		; List insert fail num. Record the static buffer count. 0~10
;Service relate 
HKR,Parameters\DriverParameters,"STATUS_07",0x00010001,0		; For sservice


[AsusFilterDrv_Service_DelReg]
HKR,Parameters

[AsusFilterDrv_Service_ALGO_DelReg]
HKR,Parameters

[AsusFilterDrv_Service_Drv_DelReg]
HKR,Parameters



