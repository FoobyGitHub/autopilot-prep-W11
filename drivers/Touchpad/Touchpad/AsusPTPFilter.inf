[AsusFilter_Inst.NT]
FeatureScore=00
CopyFiles= AsusFilter_Inst.CopyFiles.NT


;-------------- Service installation
[AsusFilter_Inst.NT.Services]
AddService = AsusPTPDrv,%SPSVCINST_ASSOCSERVICE%, AsusFilter_Service_Inst
AddService = AsusPTPService,0x00000800,AsusPTPService_Usersrv_ServiceInstall

[AsusPTPService_Usersrv_ServiceInstall]
DisplayName    = "AsusPTPService"
ServiceType    = 0x00000020      ; SERVICE_WIN32_SHARE_PROCESS
StartType      = 2               ; SERVICE_AUTO_START
ErrorControl   = 1               ; SERVICE_ERROR_NORMAL
ServiceBinary  = %13%\AsusPTPService.exe


;-------------- PTPFilter driver install sections
[AsusFilter_Service_Inst]
DisplayName    = %AsusFilter.SvcDesc%
ServiceType    = 1  ;SERVICE_KERNEL_DRIVER
StartType      = 3  ;SERVICE_DEMAND_START
ErrorControl   = 1  ;SERVICE_ERROR_NORMAL
ServiceBinary  = %13%\AsusPTPFilter.sys
LoadOrderGroup = Extended Base
AddReg	       = AsusFilterDrv_Service_AddReg, AsusFilterDrv_Service_ALGO_AddReg, AsusFilterDrv_Service_Drv_AddReg
DelReg	       = AsusFilterDrv_Service_DelReg, AsusFilterDrv_Service_ALGO_DelReg, AsusFilterDrv_Service_Drv_DelReg


[AsusFilterDrv_Service_ALGO_AddReg]
; Driver Status
; 0: Disconnect with Main Driver, 1: Enable & Connect with Main Driver, 2: Enable & This is Main Driver,
HKR,Parameters\MainParameters,"TOUCHPAD",0x00010001,0
HKR,Parameters\MainParameters,"STYRPOFF",0x00010001,0	;for STYCMD
HKR,Parameters\MainParameters,"SMARTGESTURE",0x00010001,0	;for SmartGesture
HKR,Parameters\MainParameters,"HANDWRITING",0x00010001,0	;for Handwriting
HKR,Parameters\MainParameters,"FORCE",0x00010001,0	;for Forcepad

; AP Setting Status
HKR,Parameters\APSettingParameters,"COMMONFEATURE_00",0x00010001,1	; CALCULATOR_FEATURE_ONOFF
HKR,Parameters\APSettingParameters,"STYLUS_00",0x00010001,1			; STYLUS_FEATURE_ONOFF

; Set Force parameters
HKR,Parameters\AlgoParameters,"FORCE_00",0x00010001,1                       ; Support Force,
HKR,Parameters\AlgoParameters,"FORCE_01",0x00010001,0                       ; Service Force Suspend Status (1 Suspend 0 Resume)
HKR,Parameters\AlgoParameters,"FORCE_02",0x00010001,1                       ; Force Status,
HKR,Parameters\AlgoParameters,"FORCE_03",0x00010001,1                       ; Force Level,
HKR,Parameters\AlgoParameters,"FORCE_04",0x00010001,0                       ; Force Report pressure,
HKR,Parameters\AlgoParameters,"FORCE_05",0x00010001,0                       ; Force Factory Mode,
HKR,Parameters\AlgoParameters,"FORCE_06",0x00010001,3                       ; Force Release Percnet,
HKR,Parameters\AlgoParameters,"FORCE_07",0x00010001,1                       ; Normal Force Level,
HKR,Parameters\AlgoParameters,"FORCE_08",0x00010001,2                       ; Particular Force Level, Numpad mode

; Set Haptic parameters
HKR,Parameters\AlgoParameters,"HAPTICS_00",0x00010001,1                     ; Support Haptics,
HKR,Parameters\AlgoParameters,"HAPTICS_01",0x00010001,0                     ; Service Haptics Suspend Status (1 Suspend 0 Resume)
HKR,Parameters\AlgoParameters,"HAPTICS_02",0x00010001,1                     ; Haptics Status,
HKR,Parameters\AlgoParameters,"HAPTICS_03",0x00010001,2						; Haptics Level,
HKR,Parameters\AlgoParameters,"HAPTICS_04",0x00010001,0                     ; Haptics Synchronous,
HKR,Parameters\AlgoParameters,"HAPTICS_05",0x00010001,0                     ; Haptics Factory Mode,
HKR,Parameters\AlgoParameters,"HAPTICS_06",0x00010001,1                     ; Haptics Release Level,

; Haptic Gestures
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_00",0x00010001,0		; support HapticGesture
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_01",0x00010001,1		; Haptic Gesture mode, 0:long press 1:deep press
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_02",0x00010001,1		; second haptic type
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_03",0x00010001,720		; Haptic Gesture longpress frame
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_04",0x00010001,300		; Haptic Gesture second force (g)  
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_05",0x00010001,60		; touch down at the same time threshold (frame)
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_06",0x00010001,30		; gesture finger distance threshold (10^-1 mm)  //for moving
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_07",0x00010001,3			; finger press tolerance threshold (10^-1 mm)	// press tolerance (jitter)
HKR,Parameters\AlgoParameters,"HAPTICGESTURE_PARAM_08",0x00010001,1     	; Support finger number 1~3

; Compressive force
HKR,Parameters\AlgoParameters,"COMPRESSIVEFORCE_PARAM_00",0x00010001,300	; Haptic Gesture second force (100g/300g)
HKR,Parameters\AlgoParameters,"COMPRESSIVEFORCE_PARAM_01",0x00010001,400	; Haptic Gesture second force (125g/400g)
HKR,Parameters\AlgoParameters,"COMPRESSIVEFORCE_PARAM_02",0x00010001,500	; Haptic Gesture second force (150g/500g)


; BI data
HKR,Parameters\AlgoParameters,"BIDATA_0",0x00010001,1		; version
HKR,Parameters\AlgoParameters,"BIDATA_1",0x00010001,5		; Map Report Trigger Value (to service)
HKR,Parameters\AlgoParameters,"BIDATA_2",0x00010001,250		; Tap time (ms)
HKR,Parameters\AlgoParameters,"BIDATA_3",0x00010001,2		; tap dist mm
HKR,Parameters\AlgoParameters,"BIDATA_4",0x00010001,50		; cluster dist mm
HKR,Parameters\AlgoParameters,"BIDATA_5",0x00010001,150		; cluster time (ms)
HKR,Parameters\AlgoParameters,"BIDATA_6",0x00010001,2		; force report interval (min)


;DWORD Example (REG_MULTI_SZ: 0x00010000, REG_DWORD: 0x00010001, REG_BINARY: 0x00000001)
HKR,Parameters\AlgoParameters,"FLAG_0",0x00010001,0			; FIN3SPEEDUP_FLAG_UPDOWN
HKR,Parameters\AlgoParameters,"FLAG_1",0x00010001,0			; PANSPEEDUP_FLAG  optimize scroll's trigger distance in different area into the same trigger distance 
HKR,Parameters\AlgoParameters,"FLAG_2",0x00010001,1			; PALM_FLAG
HKR,Parameters\AlgoParameters,"FLAG_3",0x00010001,1			; FILTERPALMFINGER
HKR,Parameters\AlgoParameters,"FLAG_4",0x00010001,1			; PAN_REDUCE_TRIGGER_FLAG
HKR,Parameters\AlgoParameters,"FLAG_5",0x00010001,0			; CM_REDUCE_TRIGGER_FLAG
HKR,Parameters\AlgoParameters,"FLAG_6",0x00010001,1			; filter for scroll
HKR,Parameters\AlgoParameters,"FLAG_7",0x00010001,1			; FIN3SPEEDUP_FLAG_LEFTRIGHT
HKR,Parameters\AlgoParameters,"FLAG_8",0x00010001,0			; INHERIT PALM
HKR,Parameters\AlgoParameters,"FLAG_9",0x00010001,0			; OVER_LARGE_PALM_DISABLE_REPORT
HKR,Parameters\AlgoParameters,"FLAG_10",0x00010001,1		; FLASH EDGE TAPPING


; Ratio value // SPEEDUP_RATIO, FIN3_SPEEDUP_RATIO, SPPEDUPAREA_SHIFT_L_RATIO, SPPEDUPAREA_SHIFT_R_RATIO, SPPEDUPAREA_SHIFT_B_RATIO, SPPEDUPAREA_SHIFT_T_RATIO
; Ratio value // TAPPING_DEFLATE_L_RATIO, TAPPING_DEFLATE_R_RATIO, TAPPING_DEFLATE_B_RATIO, TAPPING_DEFLATE_T_RATIO
HKR,Parameters\AlgoParameters,"RATIO_0",0x00010001,4		; SPEEDUP_RATIO
HKR,Parameters\AlgoParameters,"RATIO_1",0x00010001,7		; FIN3_SPEEDUP_RATIO
HKR,Parameters\AlgoParameters,"RATIO_2",0x00010001,5		; SPPEDUPAREA_SHIFT_L_RATIO
HKR,Parameters\AlgoParameters,"RATIO_3",0x00010001,5		; SPPEDUPAREA_SHIFT_R_RATIO
HKR,Parameters\AlgoParameters,"RATIO_4",0x00010001,12		; SPPEDUPAREA_SHIFT_B_RATIO
HKR,Parameters\AlgoParameters,"RATIO_5",0x00010001,0		; SPPEDUPAREA_SHIFT_T_RATIO
HKR,Parameters\AlgoParameters,"RATIO_6",0x00010001,10		; TAPPING_DEFLATE_L_RATIO
HKR,Parameters\AlgoParameters,"RATIO_7",0x00010001,10		; TAPPING_DEFLATE_R_RATIO
HKR,Parameters\AlgoParameters,"RATIO_8",0x00010001,10		; TAPPING_DEFLATE_B_RATIO
HKR,Parameters\AlgoParameters,"RATIO_9",0x00010001,0		; TAPPING_DEFLATE_T_RATIO
HKR,Parameters\AlgoParameters,"RATIO_10",0x00010001,10		; PALM_DEFLATE_L_RATIO
HKR,Parameters\AlgoParameters,"RATIO_11",0x00010001,10		; PALM_DEFLATE_R_RATIO
HKR,Parameters\AlgoParameters,"RATIO_12",0x00010001,16		; PALM_DEFLATE_B_RATIO
HKR,Parameters\AlgoParameters,"RATIO_13",0x00010001,0		; PALM_DEFLATE_T_RATIO
HKR,Parameters\AlgoParameters,"RATIO_14",0x00010001,300		; Inertia Ratio Med
HKR,Parameters\AlgoParameters,"RATIO_15",0x00010001,100		; Inertia Ratio Slow
HKR,Parameters\AlgoParameters,"RATIO_16",0x00010001,450		; Inertia Ratio Fast
HKR,Parameters\AlgoParameters,"RATIO_17",0x00010001,0		; filter for scroll ratio
HKR,Parameters\AlgoParameters,"RATIO_18",0x00010001,25		; Resting finger area (0 ~ 100)
HKR,Parameters\AlgoParameters,"RATIO_19",0x00010001,4		; Edge palm: Left ratio
HKR,Parameters\AlgoParameters,"RATIO_20",0x00010001,4		; Edge palm: right ratio
HKR,Parameters\AlgoParameters,"RATIO_21",0x00010001,6		; Edge palm: Top ratio
HKR,Parameters\AlgoParameters,"RATIO_22",0x00010001,0		; Edge palm: bottom ratio

; Minimeter value // MOVING_THRESHOLD_MM, MAX_SPEEDUP_THRESHOLD_MM, TAPPING_THRESHOLD_MM
HKR,Parameters\AlgoParameters,"MINIMETER_0",0x00010001,15
HKR,Parameters\AlgoParameters,"MINIMETER_1",0x00010001,100
HKR,Parameters\AlgoParameters,"MINIMETER_2",0x00010001,6
HKR,Parameters\AlgoParameters,"MINIMETER_3",0x00010001,50
;HKR,Parameters\AlgoParameters,"MINIMETER_3",0x00010001,0
HKR,Parameters\AlgoParameters,"MINIMETER_4",0x00010001,4
HKR,Parameters\AlgoParameters,"MINIMETER_5",0x00010001,4
HKR,Parameters\AlgoParameters,"MINIMETER_6",0x00010001,6
HKR,Parameters\AlgoParameters,"MINIMETER_7",0x00010001,28
HKR,Parameters\AlgoParameters,"MINIMETER_8",0x00010001,10
HKR,Parameters\AlgoParameters,"MINIMETER_9",0x00010001,4
HKR,Parameters\AlgoParameters,"MINIMETER_10",0x00010001,10
